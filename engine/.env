# Local dev: engine proxies to your local backend
PORT=8080
ENGINE_BASE_PATH=/api

# Local backend
BACKEND_ORIGINS=http://localhost:5000

# Health checks
HEALTH_PATH=/api/health
HEALTH_INTERVAL_MS=5000
HEALTH_TIMEOUT_MS=1500
HEALTH_UNHEALTHY_STATUS_MIN=500

# Proxy timeouts
PROXY_TIMEOUT_MS=15000
PROXY_LOG_LEVEL=warn
